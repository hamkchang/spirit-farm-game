# OP / GE AI proxy configuration.
# Keep real values in `.env` locally or in your cloud host's secret settings.

# OP: Anthropic-compatible Opus agent
OP_MODEL=opus-4.8
OP_API_KEY=
ANTHROPIC_API_KEY=
METACLAW_ADS_ANTHROPIC_TOKEN=

# GE: Google Gemini agent
GE_MODEL=gemini-3.5-flash
GE_API_KEY=
GEMINI_API_KEY=
METACLAW_ADS_GEMINI_TOKEN=

# Optional tuning
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.4
ANTHROPIC_VERSION=2023-06-01
GEMINI_API_STYLE=interactions
